# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://revneu:revneu_secret@localhost:5432/revneu_db
POSTGRES_USER=revneu
POSTGRES_PASSWORD=revneu_secret
POSTGRES_DB=revneu_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (generate with: openssl rand -base64 48) ───────────────────────────
JWT_SECRET=change-me-min-32-chars-in-production-jwt-secret
JWT_REFRESH_SECRET=change-me-min-32-chars-in-production-refresh-secret
NEXTAUTH_SECRET=change-me-min-32-chars-in-production-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Encryption (AES-256 — generate with: openssl rand -hex 32) ──────────────
ENCRYPTION_KEY=change-me-32-byte-hex-key-for-encrypting-integration-credentials

# ─── API URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
AGENT_SERVICE_URL=http://localhost:8000
AGENT_API_KEY=change-me-internal-agent-api-key
AGENT_PERSISTENCE_MODE=auto

# ─── AI / LLM ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Payments ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=paystack-webhook-secret
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── OAuth Integrations ──────────────────────────────────────────────────────
GA4_CLIENT_ID=...
GA4_CLIENT_SECRET=...
GOOGLE_ADS_CLIENT_ID=...
GOOGLE_ADS_CLIENT_SECRET=...
META_APP_ID=...
META_APP_SECRET=...

# ─── Integration Security & Observability ───────────────────────────────────
INTEGRATION_CREDENTIALS_KEY=change-me-32-byte-entropy-string
INTEGRATION_OAUTH_STATE_SECRET=change-me-oauth-state-signing-secret
REAUTH_ALERT_THRESHOLD=3

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
