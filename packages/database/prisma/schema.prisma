// Revneu OS — Prisma Schema
// Stage 1: Core foundation models (Organizations + Users)
// Full schema with integrations, metrics, agents, billing added in Stages 2–6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum SubscriptionTier {
  TRIAL
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELED
}

enum Industry {
  FINTECH
  ECOMMERCE
  EDTECH
  LOGISTICS
  SAAS
  MARKETING_AGENCY
  OTHER
}

enum IntegrationSource {
  GA4
  META_ADS
  GOOGLE_ADS
  HUBSPOT
  PAYSTACK
  STRIPE
  SHOPIFY
  FLUTTERWAVE
  TIKTOK_ADS
  SALESFORCE
}

enum IntegrationAuthType {
  OAUTH
  API_KEY
  WEBHOOK
}

enum IntegrationStatus {
  ACTIVE
  NEEDS_REAUTH
  ERROR
  DISCONNECTED
}

enum SyncRunStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  DEAD_LETTER
}

enum MetricType {
  SPEND
  REVENUE
  SESSIONS
  CONVERSIONS
  CLICKS
  IMPRESSIONS
  CAC
  ROAS
  LTV
}

// ─── CORE MODELS ─────────────────────────────────────────────────────────────

model Organization {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  industry           Industry           @default(OTHER)
  country            String             @default("NG")
  currency           String             @default("NGN")
  timezone           String             @default("Africa/Lagos")
  subscriptionTier   SubscriptionTier   @default(TRIAL)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users                  User[]
  integrationConnections IntegrationConnection[]
  integrationSyncRuns    IntegrationSyncRun[]
  metricRecords          MetricRecord[]

  @@map("organizations")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String
  role           UserRole  @default(VIEWER)
  emailVerified  Boolean   @default(false)
  lastLoginAt    DateTime?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("users")
}

// ─── AUTH SESSIONS & TOKENS ──────────────────────────────────────────────────

model Session {
  id                String    @id @default(cuid())
  userId            String
  organizationId    String
  refreshTokenHash  String
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?
  isRevoked         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@map("sessions")
}

// ─── API KEYS ────────────────────────────────────────────────────────────────

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@map("api_keys")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  action          String   // "user.created", "org.invite_sent", etc.
  resourceType    String   // "user", "organization", "api_key"
  resourceId      String?
  changes         Json?    // Old and new values
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model IntegrationConnection {
  id                   String              @id @default(cuid())
  organizationId       String
  source               IntegrationSource
  authType             IntegrationAuthType
  displayName          String
  encryptedCredentials String
  status               IntegrationStatus   @default(ACTIVE)
  syncIntervalMinutes  Int                 @default(60)
  lastSyncAt           DateTime?
  errorCount           Int                 @default(0)
  healthScore          Int                 @default(100)
  createdByUserId      String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncRuns     IntegrationSyncRun[]
  metricRecords MetricRecord[]

  @@unique([organizationId, source, displayName])
  @@index([organizationId, source])
  @@index([status])
  @@map("integration_connections")
}

model IntegrationSyncRun {
  id             String       @id @default(cuid())
  organizationId String
  integrationId  String
  status         SyncRunStatus @default(QUEUED)
  startedAt      DateTime      @default(now())
  finishedAt     DateTime?
  retryCount     Int           @default(0)
  nextRetryAt    DateTime?
  recordsIngested Int          @default(0)
  errorMessage   String?
  createdAt      DateTime      @default(now())

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration  IntegrationConnection @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([organizationId, startedAt])
  @@index([integrationId, status])
  @@map("integration_sync_runs")
}

model MetricRecord {
  id             String            @id @default(cuid())
  organizationId String
  integrationId  String?
  source         IntegrationSource
  metricType     MetricType
  dimension      String
  value          Float
  currency       String            @default("NGN")
  recordedAt     DateTime
  periodStart    DateTime
  periodEnd      DateTime
  rawPayload     Json?
  createdAt      DateTime          @default(now())

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration  IntegrationConnection? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([organizationId, source, metricType, recordedAt])
  @@index([integrationId, recordedAt])
  @@map("metric_records")
}
