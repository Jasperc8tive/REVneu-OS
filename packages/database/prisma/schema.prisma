// Revneu OS — Prisma Schema
// Stage 1: Core foundation models (Organizations + Users)
// Full schema with integrations, metrics, agents, billing added in Stages 2–6

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum SubscriptionTier {
  TRIAL
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELED
}

enum Industry {
  FINTECH
  ECOMMERCE
  EDTECH
  LOGISTICS
  SAAS
  MARKETING_AGENCY
  OTHER
}

enum IntegrationSource {
  GA4
  META_ADS
  GOOGLE_ADS
  HUBSPOT
  PAYSTACK
  STRIPE
  SHOPIFY
  FLUTTERWAVE
  TIKTOK_ADS
  SALESFORCE
}

enum IntegrationAuthType {
  OAUTH
  API_KEY
  WEBHOOK
}

enum IntegrationStatus {
  ACTIVE
  NEEDS_REAUTH
  ERROR
  DISCONNECTED
}

enum SyncRunStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  DEAD_LETTER
}

enum MetricType {
  SPEND
  REVENUE
  SESSIONS
  CONVERSIONS
  CLICKS
  IMPRESSIONS
  CAC
  ROAS
  LTV
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

// ─── CORE MODELS ─────────────────────────────────────────────────────────────

model Organization {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  industry           Industry           @default(OTHER)
  country            String             @default("NG")
  currency           String             @default("NGN")
  timezone           String             @default("Africa/Lagos")
  subscriptionTier   SubscriptionTier   @default(TRIAL)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users                  User[]
  integrationConnections IntegrationConnection[]
  integrationSyncRuns    IntegrationSyncRun[]
  metricRecords          MetricRecord[]
  agentRuns              AgentRun[]
  recommendations        Recommendation[]
  agentSchedules         AgentSchedule[]

  @@map("organizations")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String
  role           UserRole  @default(VIEWER)
  emailVerified  Boolean   @default(false)
  lastLoginAt    DateTime?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("users")
}

// ─── AUTH SESSIONS & TOKENS ──────────────────────────────────────────────────

model Session {
  id                String    @id @default(cuid())
  userId            String
  organizationId    String
  refreshTokenHash  String
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?
  isRevoked         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@map("sessions")
}

// ─── API KEYS ────────────────────────────────────────────────────────────────

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@map("api_keys")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  action          String   // "user.created", "org.invite_sent", etc.
  resourceType    String   // "user", "organization", "api_key"
  resourceId      String?
  changes         Json?    // Old and new values
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model IntegrationConnection {
  id                   String              @id @default(cuid())
  organizationId       String              @map("organization_id")
  source               IntegrationSource
  authType             IntegrationAuthType @map("auth_type")
  displayName          String              @map("display_name")
  encryptedCredentials String              @map("encrypted_credentials")
  status               IntegrationStatus   @default(ACTIVE)
  syncIntervalMinutes  Int                 @default(60) @map("sync_interval_minutes")
  lastSyncAt           DateTime?           @map("last_sync_at")
  errorCount           Int                 @default(0) @map("error_count")
  healthScore          Int                 @default(100) @map("health_score")
  createdByUserId      String?             @map("created_by_user_id")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncRuns     IntegrationSyncRun[]
  metricRecords MetricRecord[]

  @@unique([organizationId, source, displayName])
  @@index([organizationId, source])
  @@index([status])
  @@map("integration_connections")
}

model IntegrationSyncRun {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  integrationId  String       @map("integration_id")
  status         SyncRunStatus @default(QUEUED)
  startedAt      DateTime      @default(now()) @map("started_at")
  finishedAt     DateTime?     @map("finished_at")
  retryCount     Int           @default(0) @map("retry_count")
  nextRetryAt    DateTime?     @map("next_retry_at")
  recordsIngested Int          @default(0) @map("records_ingested")
  errorMessage   String?       @map("error_message")
  createdAt      DateTime      @default(now()) @map("created_at")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration  IntegrationConnection @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([organizationId, startedAt])
  @@index([integrationId, status])
  @@map("integration_sync_runs")
}

model MetricRecord {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  integrationId  String?           @map("integration_id")
  source         IntegrationSource
  metricType     MetricType        @map("metric_type")
  dimension      String
  value          Float
  currency       String            @default("NGN")
  recordedAt     DateTime          @map("recorded_at")
  periodStart    DateTime          @map("period_start")
  periodEnd      DateTime          @map("period_end")
  rawPayload     Json?             @map("raw_payload")
  createdAt      DateTime          @default(now()) @map("created_at")

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration  IntegrationConnection? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([organizationId, source, metricType, recordedAt])
  @@index([integrationId, recordedAt])
  @@map("metric_records")
}

model AgentRun {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  agentId        String        @map("agent_id")
  period         String
  status         AgentRunStatus @default(RUNNING)
  startedAt      DateTime       @default(now()) @map("started_at")
  finishedAt     DateTime?      @map("finished_at")
  durationMs     Int?           @map("duration_ms")
  tokensUsed     Int            @default(0) @map("tokens_used")
  tokenCostUsd   Float          @default(0) @map("token_cost_usd")
  error          String?
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@index([organizationId, createdAt])
  @@index([organizationId, agentId, status])
  @@map("agent_runs")
}

model Recommendation {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  agentRunId     String   @map("agent_run_id")
  agentId        String   @map("agent_id")
  summary        String?
  findings       Json
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentRun     AgentRun     @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, agentId])
  @@index([agentRunId])
  @@map("recommendations")
}

model AgentSchedule {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  cadenceMinutes Int           @default(60) @map("cadence_minutes")
  isEnabled      Boolean       @default(true) @map("is_enabled")
  lastTriggeredAt DateTime?    @map("last_triggered_at")
  lastRunStatus  AgentRunStatus? @map("last_run_status")
  lastError      String?       @map("last_error")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId])
  @@index([isEnabled, cadenceMinutes])
  @@map("agent_schedules")
}
